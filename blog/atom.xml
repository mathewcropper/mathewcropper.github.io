---
layout: feed
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">

	<title>Mathew Cropper</title>
	<link href="http://mathewcropper.co.uk/blog/atom.xml" rel="self"/>
	<link href="http://mathewcropper.co.uk"/>
	<updated>{{ site.time | date_to_xmlschema }}</updated>
	<id>http://mathewcropper.co.uk</id>
	<author>
		<name>Mathew Cropper</name>
	</author>

	{% for post in site.posts %}
		<entry>
			<title>{{ post.title }}</title>
			<link href="http://mathewcropper.co.uk{{ post.url }}"/>
			<updated>{{ post.date | date_to_xmlschema }}</updated>
			<id>http://mathewcropper.co.uk/{{ post.id }}</id>
			<content type="html">{{ post.content | xml_escape }}</content>
		</entry>
	{% endfor %}

</feed>
